# Copia este archivo como .env y agrega tus llaves reales de Stripe
STRIPE_SECRET_KEY=sk_test_REEMPLAZA_CON_TU_LLAVE
PORT=4242
APP_URL=http://localhost:5500
STRIPE_API_BASE=https://tusllantas-production.up.railway.app

# Inventario en vivo desde Google Sheets (publicado como CSV)
# Ejemplo: https://docs.google.com/spreadsheets/d/<ID>/gviz/tq?tqx=out:csv&sheet=Inventario
SHEET_CSV_URL=
SHEET_LOCAL_CSV=
AUTO_SYNC_MS=30000

# SerpAPI para busqueda automatica de productos/imagenes
SERPAPI_KEY=

# Cloudinary para optimizar y almacenar imagenes
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Opcional: IDs de cupones creados en Stripe Dashboard
# STRIPE_COUPON_RIN10=coupon_xxxxxxxxx
# STRIPE_COUPON_AT5=coupon_xxxxxxxxx
